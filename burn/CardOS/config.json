{
  "name": "CardOS",
  "version": "0.1.0",
  "author": "CardOS Team",
  "website": "https://github.com/cardpda/cardos",
  "chip": "esp32s3",
  "platform": "arduino",
  "description": "CardOS - Modular Personal Operating System for M5Stack Cardputer",
